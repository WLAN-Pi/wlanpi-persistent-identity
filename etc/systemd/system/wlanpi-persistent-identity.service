[Unit]
Description=Persistent system identity for A/B partitions
Documentation=https://github.com/wlan-pi/wlanpi-persistent-identity
DefaultDependencies=no
Conflicts=shutdown.target
Before=shutdown.target
After=local-fs.target expand-home-partition.service
ConditionPathIsReadWrite=/etc
RequiresMountsFor=/home

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/usr/local/sbin/setup-persistent-identity

[Install]
WantedBy=sysinit.target